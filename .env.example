# CodeClaw environment example
# Copy to .env.local or export the variables in your shell.
# Do not put real secrets in files that may be committed.

# Provider API keys.
# Keep real key values outside git; match these names from ~/.codeclaw/providers.json.
CODECLAW_OPENAI_API_KEY=
CODECLAW_ANTHROPIC_API_KEY=
CODECLAW_LMSTUDIO_API_KEY=
CODECLAW_OLLAMA_API_KEY=

# Runtime output guards.
# CODECLAW_* names are preferred. CHATBI_* names are still accepted only as legacy compatibility fallbacks.
CODECLAW_MAX_TURN_BYTES=65536
CODECLAW_TERMINAL_RENDER_BYTES=24576
CODECLAW_MAX_OUTPUT_RECOVERY_TURNS=2
CODECLAW_MAX_UNDELIMITED_STREAM_BUFFER_BYTES=2097152
CODECLAW_STREAM_IDLE_MS=60000
CODECLAW_TOKEN_WARN_THRESHOLD=0.7
CODECLAW_AUTO_COMPACT_THRESHOLD=0.85

# Tool-loop guards.
CODECLAW_MAX_TOOL_TURNS=24
CODECLAW_REPEATED_TOOL_CALL_LIMIT=5
CODECLAW_LOW_PROGRESS_TOOL_TURNS=4

# Provider circuit breaker.
CODECLAW_PROVIDER_MAX_CONCURRENCY=2
CODECLAW_PROVIDER_STUCK_THRESHOLD=2
CODECLAW_PROVIDER_COOLDOWN_MS=30000
CODECLAW_PROVIDER_TRANSIENT_THRESHOLD=3
CODECLAW_PROVIDER_TRANSIENT_COOLDOWN_MS=10000

# Optional budget guards.
CODECLAW_BUDGET_SESSION_USD=
CODECLAW_BUDGET_TODAY_USD=
CODECLAW_BUDGET_SESSION_TOKENS=
CODECLAW_BUDGET_TODAY_TOKENS=
CODECLAW_BUDGET_ON_EXCEEDED=warn
CODECLAW_BUDGET_WARN_AT=0.7

# Native tools toggles.
CODECLAW_NATIVE_TOOLS=true
CODECLAW_PROJECT_MEMORY=true
CODECLAW_PLAN_MODE_STRICT=true
CODECLAW_SUBAGENT=true
CODECLAW_KNOWLEDGE=true
CODECLAW_RAG=true
CODECLAW_GRAPH=true
CODECLAW_CRON=true

# RAG embeddings.
CODECLAW_RAG_EMBED_MODEL=bge-m3
CODECLAW_RAG_EMBED_BASE_URL=

# Local gateway / web / WeChat tokens.
CODECLAW_GATEWAY_TOKEN=
CODECLAW_WEB_TOKEN=
CODECLAW_WECHAT_TOKEN=
CODECLAW_ILINK_WECHAT_TOKEN_FILE=~/.claude/wechat-ibot/default.json
CODECLAW_ILINK_WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
CODECLAW_ILINK_WECHAT_POLL_INTERVAL_MS=1000

# Beelink MCP.
BEELINK_BASE_URL=
BEELINK_USERNAME=
BEELINK_PASSWORD=
BEELINK_TIMEOUT_MS=30000
BEELINK_PREVIEW_ROWS=5
BEELINK_MAX_PREVIEW_ROWS=50
BEELINK_EXPORT_MAX_ROWS=5000
BEELINK_EXPORT_PAGE_ROWS=500
BEELINK_ARTIFACTS_ROOT=
BEELINK_METADATA_DB=
BEELINK_SEMANTIC_LAYER=
BEELINK_GLOSSARY=

# DICOM MCP.
CODECLAW_DICOM_MAX_FILE_BYTES=268435456

# LSP.
# unset = auto; 1 = force real multilspy LSP; 0 = force regex fallback.
CODECLAW_ENABLE_REAL_LSP=
CODECLAW_PYTHON=
CODECLAW_LSP_BRIDGE_SCRIPT=

# Debug / compatibility.
CODECLAW_SKIP_PROVIDER_PROBE=
CODECLAW_SHOW_THINKING=
CODECLAW_STREAM_OUTPUT=
CODECLAW_NO_PROMPT_REDACT=
CODECLAW_LOG_LEVEL=info
